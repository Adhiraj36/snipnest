{
  "name": "snipnest",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.11",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "nanoid": "^5.1.6"
  }
}
