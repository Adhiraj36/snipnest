{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "NODE_TLS_REJECT_UNAUTHORIZED=0 bunx drizzle-kit migrate",
    "db:browser": "bunx drizzle-kit studio --host=0.0.0.0"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "nanoid": "^5.1.6",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.6.1",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
